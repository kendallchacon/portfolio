---
import { Icon } from "astro-icon/components";
---

<header
  class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="#home" class="text-lg font-bold tracking-tight text-white">
      Kendall
    </a>

    <div
      class="hidden items-center gap-8 text-sm font-medium text-slate-300 md:flex"
    >
      <a href="/" class="transition hover:text-cyan-400">Inicio</a>
      <a href="/perfil" class="transition hover:text-cyan-400">Perfil</a>
      <a href="/habilidades" class="transition hover:text-cyan-400"
        >Habilidades</a
      >
      <a href="/proyectos" class="transition hover:text-cyan-400">Proyectos</a>
      <a href="/contacto" class="transition hover:text-cyan-400">Contacto</a>

      <a
        href="/cv-kendall-chacon.pdf"
        download
        class="btn-primary-animated inline-flex items-center justify-center rounded-full bg-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300"
      >
        <span>Descargar CV</span>
      </a>
    </div>
  </nav>
</header>
