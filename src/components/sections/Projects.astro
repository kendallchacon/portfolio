---
import { Icon } from "astro-icon/components";
import TechBadge from "../common/TechBadge.astro";
import { featuredProject } from "../../data/projects";
---

<section
  id="proyecto-principal"
  class="reveal border-t border-slate-800 py-24 sm:py-32"
>
  <div class="mx-auto max-w-6xl px-0 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-400">
      {featuredProject.eyebrow}
    </p>

    <h2
      class="mt-4 max-w-3xl text-3xl font-bold tracking-tight text-white sm:text-4xl"
    >
      {featuredProject.title}
    </h2>

    <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-300">
      {featuredProject.summary}
    </p>

    <article
      class="group relative mt-12 overflow-hidden rounded-3xl border border-slate-700 bg-slate-900/50 transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40"
    >
      <div
        class="absolute -top-20 right-0 h-72 w-72 rounded-full bg-cyan-400/10 blur-3xl"
      >
      </div>

      <div class="relative overflow-hidden border-b border-slate-800">
        <img
          src={featuredProject.image}
          alt={featuredProject.imageAlt}
          class="w-full bg-slate-950 object-contain"
        />

        <div
          class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"
        >
        </div>
      </div>

      <div class="relative p-5 sm:p-10">
        <div class="flex flex-wrap gap-3">
          {
            featuredProject.stack.map((tech) => (
              <TechBadge {...tech} compact />
            ))
          }
        </div>

        <h3 class="mt-8 text-2xl font-semibold text-white">
          {featuredProject.overview.title}
        </h3>

        <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
          {featuredProject.overview.description}
        </p>

        <div class="mt-10 grid gap-4 md:grid-cols-2">
          {
            featuredProject.caseStudy.map((item) => (
              <div class="rounded-2xl border border-slate-800 bg-slate-950/50 p-5">
                <h4 class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-400">
                  {item.title}
                </h4>
                <p class="mt-3 text-sm leading-6 text-slate-300">
                  {item.description}
                </p>
              </div>
            ))
          }
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
          <div>
            <h4 class="text-lg font-semibold text-white">Módulos</h4>
            <div class="mt-4 grid gap-3">
              {
                featuredProject.modules.map((module) => (
                  <div class="flex items-start gap-3 rounded-2xl border border-slate-800 bg-slate-950/50 px-4 py-3 text-sm text-slate-300">
                    <Icon
                      name="heroicons:check-circle"
                      class="mt-0.5 size-5 text-cyan-400"
                    />
                    <span>{module}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <div>
            <h4 class="text-lg font-semibold text-white">
              Decisiones técnicas
            </h4>
            <div class="mt-4 grid gap-3">
              {
                featuredProject.technicalDecisions.map((decision) => (
                  <div class="flex items-start gap-3 rounded-2xl border border-slate-800 bg-slate-950/50 px-4 py-3 text-sm text-slate-300">
                    <Icon
                      name="heroicons:code-bracket-square"
                      class="mt-0.5 size-5 text-cyan-400"
                    />
                    <span>{decision}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          <div class="rounded-2xl border border-slate-800 bg-slate-950/50 p-5">
            <h4 class="text-lg font-semibold text-white">Base de datos</h4>
            <p class="mt-3 text-sm leading-6 text-slate-300">
              {featuredProject.database}
            </p>
          </div>

          <div class="rounded-2xl border border-slate-800 bg-slate-950/50 p-5">
            <h4 class="text-lg font-semibold text-white">Seguridad</h4>
            <div class="mt-4 grid gap-3">
              {
                featuredProject.security.map((item) => (
                  <div class="flex items-start gap-3 text-sm text-slate-300">
                    <Icon
                      name="heroicons:shield-check"
                      class="mt-0.5 size-5 text-cyan-400"
                    />
                    <span>{item}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <p class="mt-8 text-sm leading-6 text-slate-400">
          El código del sistema no se publica como repositorio abierto. La
          evidencia principal se presenta aquí como caso de estudio técnico.
        </p>
      </div>
    </article>
  </div>
</section>
