---
import ButtonLink from "../common/ButtonLink.astro";
---

<section id="home" class="py-16 sm:py-24">
  <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
    <!-- Contenido principal -->
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-400">
        Desarrollo web · APIs · Soluciones digitales
      </p>

      <h1
        class="mt-6 max-w-4xl text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl"
      >
        Diseño y desarrollo de aplicaciones web completas que conectan
        <span id="hero-word" class="text-cyan-400 hero-word">ideas</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-400">
        Trabajo con un enfoque en estructura, claridad y mantenibilidad,
        construyendo sistemas pensados para crecer y adaptarse a necesidades
        reales.
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <ButtonLink href="/proyectos">Ver proyectos</ButtonLink>

        <ButtonLink href="/contacto" variant="secondary">
          Contactarme
        </ButtonLink>
      </div>
    </div>

    <!-- Panel visual interactivo -->
    <div class="group relative">
      <div
        class="absolute -inset-4 rounded-[2rem] bg-cyan-400/10 blur-3xl transition duration-500 group-hover:bg-cyan-400/20"
      >
      </div>

      <div
        class="relative overflow-hidden rounded-3xl border border-slate-800 bg-slate-950/80 shadow-2xl transition duration-500 group-hover:-translate-y-2 group-hover:border-cyan-400/40"
      >
        <div
          class="flex items-center gap-2 border-b border-slate-800 px-5 py-4"
        >
          <span class="h-3 w-3 rounded-full bg-red-400"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
          <span class="h-3 w-3 rounded-full bg-green-400"></span>
          <span class="ml-auto text-xs text-slate-500">backend-system.ts</span>
        </div>

        <div class="space-y-5 p-6 font-mono text-sm">
          <p class="terminal-line terminal-delay-1 text-slate-500">
            <span class="text-cyan-400">$</span> init project<span
              class="terminal-cursor">_</span
            >
          </p>

          <div
            class="terminal-line terminal-delay-2 rounded-2xl border border-slate-800 bg-slate-900/50 p-4 transition group-hover:border-cyan-400/30"
          >
            <p class="text-cyan-400">const stack = &#123;</p>
            <p class="pl-4 text-slate-300">frontend: "Vue + Tailwind",</p>
            <p class="pl-4 text-slate-300">
              backend: "Laravel | Node | Spring",
            </p>
            <p class="pl-4 text-slate-300">database: "MySQL | SQL Server"</p>
            <p class="text-cyan-400">&#125;</p>
          </div>

          <div class="grid gap-3 text-slate-300">
            <div
              class="terminal-line terminal-delay-3 rounded-xl border border-slate-800 px-4 py-3 transition group-hover:border-cyan-400/30"
            >
              <div class="flex items-center justify-between">
                <span>APIs REST</span>
                <span class="terminal-status status-delay-1 text-cyan-400"
                  >ready</span
                >
              </div>
              <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-slate-800">
                <div
                  class="load-bar load-delay-1 h-full rounded-full bg-cyan-400"
                >
                </div>
              </div>
            </div>

            <div
              class="terminal-line terminal-delay-4 rounded-xl border border-slate-800 px-4 py-3 transition group-hover:border-cyan-400/30"
            >
              <div class="flex items-center justify-between">
                <span>Arquitectura modular</span>
                <span class="terminal-status status-delay-2 text-cyan-400"
                  >clean</span
                >
              </div>
              <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-slate-800">
                <div
                  class="load-bar load-delay-2 h-full rounded-full bg-cyan-400"
                >
                </div>
              </div>
            </div>

            <div
              class="terminal-line terminal-delay-5 rounded-xl border border-slate-800 px-4 py-3 transition group-hover:border-cyan-400/30"
            >
              <div class="flex items-center justify-between">
                <span>Sistemas mantenibles</span>
                <span class="terminal-status status-delay-3 text-cyan-400"
                  >scalable</span
                >
              </div>
              <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-slate-800">
                <div
                  class="load-bar load-delay-3 h-full rounded-full bg-cyan-400"
                >
                </div>
              </div>
            </div>
          </div>

          <p class="terminal-line terminal-delay-6 text-slate-500">
            <span class="text-cyan-400">✓</span> solución lista para crecer
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
