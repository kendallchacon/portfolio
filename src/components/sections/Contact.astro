---
import { Icon } from "astro-icon/components";
import ButtonLink from "../common/ButtonLink.astro";
import Tag from "../common/Tag.astro";
import { contactLinks, contactTags } from "../../data/contact";
---

<section id="contact" class="reveal border-t border-slate-800 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-0 sm:px-6">
    <div class="grid items-center gap-14 lg:grid-cols-[1fr_1fr]">
      <div>
        <p
          class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-400"
        >
          Contacto
        </p>

        <h2
          class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl"
        >
          Disponible para práctica profesional en desarrollo backend / full
          stack
        </h2>

        <p class="mt-6 max-w-xl text-lg leading-8 text-slate-300">
          Busco integrarme a un equipo donde pueda aportar en APIs REST,
          bases de datos relacionales, validaciones backend, autenticación,
          roles y flujos de negocio con Laravel y tecnologías web.
        </p>

        <p class="mt-4 max-w-xl text-sm leading-6 text-slate-300">
          Puedes contactarme para revisar mi perfil, conversar sobre una
          práctica profesional o coordinar una entrevista técnica.
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          {
            contactTags.map((tag) => (
              <Tag size="sm" featured={tag.featured}>{tag.label}</Tag>
            ))
          }
        </div>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <ButtonLink href="mailto:kendallchacon4@gmail.com">
            Contactarme para práctica profesional
          </ButtonLink>

          <ButtonLink
            href="/cv-kendall-chacon.pdf"
            download="cv-kendall-chacon.pdf"
            variant="secondary"
          >
            Descargar CV
          </ButtonLink>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          contactLinks.map((link) => (
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noreferrer" : undefined}
              class="group flex items-center gap-4 rounded-2xl border border-slate-800 bg-slate-900/40 p-5 transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40"
            >
              <Icon
                name={link.icon}
                class:list={[
                  "size-[22px] transition duration-300 group-hover:scale-125",
                  link.iconClass,
                ]}
              />
              <div>
                <p class="font-semibold text-white">{link.label}</p>
                <p class="text-xs text-slate-300">{link.description}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
