---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExperienceCard from "../components/common/ExperienceCard.astro";
import IconCard from "../components/common/IconCard.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import Tag from "../components/common/Tag.astro";
import {
  experienceItems,
  profileTags,
  timelineItems,
} from "../data/profile";
---

<BaseLayout
  title="Perfil | Kendall Chacón"
  description="Perfil profesional de Kendall Chacón, desarrollador web enfocado en backend, APIs y soluciones completas."
  image="/images/kendall-profile.jpg"
  type="profile"
>
  <section class="py-20 sm:py-28">
    <div
      class="mx-auto grid max-w-6xl items-center gap-12 px-0 sm:px-6 lg:grid-cols-[1.1fr_0.9fr]"
    >
      <div class="reveal">
        <SectionHeader
          eyebrow="Perfil profesional"
          title="Desarrollador web enfocado en soluciones completas."
          titleTag="h1"
          description="Construyo aplicaciones web claras, funcionales y bien estructuradas, combinando frontend, backend y bases de datos."
        />

        <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-400">
          Mi fortaleza está en backend, APIs y lógica de negocio, integrándolo
          con interfaces pensadas para el usuario.
        </p>

        <div class="mt-8 flex flex-wrap gap-3 text-sm">
          {profileTags.map((tag) => <Tag>{tag}</Tag>)}
        </div>
      </div>

      <div class="reveal flex justify-center lg:justify-end">
        <div class="group relative w-full max-w-sm">
          <div
            class="absolute -inset-4 rounded-[2rem] bg-cyan-400/10 blur-3xl transition group-hover:bg-cyan-400/20"
          >
          </div>

          <div
            class="relative overflow-hidden rounded-3xl border border-slate-800 bg-slate-900/40 shadow-2xl transition duration-300 group-hover:-translate-y-1 group-hover:border-cyan-400/40"
          >
            <img
              src="/images/kendall-profile.jpg"
              alt="Kendall Chacón"
              class="h-96 w-full object-cover object-top"
            />

            <div class="border-t border-slate-800 p-6">
              <h2 class="text-lg font-semibold text-white">Kendall Chacón</h2>

              <p class="mt-2 text-sm text-slate-400">
                Ingeniería en Sistemas · Desarrollo web
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal border-t border-slate-800 py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-0 sm:px-6">
      <SectionHeader
        eyebrow="Trayectoria"
        title="Formación y experiencia"
        description="Mi recorrido combina formación académica, desarrollo de software y acompañamiento a estudiantes en procesos de aprendizaje tecnológico."
      />

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          timelineItems.map((item, index) => (
            <IconCard
              {...item}
              reveal
              delay={(index + 1) * 0.1}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="reveal border-t border-slate-800 py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-0 sm:px-6">
      <SectionHeader
        eyebrow="Experiencias"
        title="Actividades participadas"
        description="Actividades donde he fortalecido comunicación, liderazgo y capacidad para explicar temas técnicos a diferentes públicos."
      />

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {
          experienceItems.map((item, index) => (
            <ExperienceCard {...item} delay={(index + 1) * 0.1} />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
