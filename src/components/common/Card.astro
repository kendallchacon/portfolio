---
interface Props {
  class?: string;
  reveal?: boolean;
  delay?: number;
}

const { class: className = "", reveal = false, delay } = Astro.props;
---

<article
  class:list={[
    reveal && "reveal",
    "group relative overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40 transition duration-300 hover:-translate-y-2 hover:border-cyan-400/40 hover:bg-slate-900/70",
    className,
  ]}
  style={delay !== undefined ? `transition-delay: ${delay}s;` : undefined}
>
  <slot />
  <div class="card-line"></div>
</article>

