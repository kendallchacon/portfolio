---
import "../styles/global.css";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/sections/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "profile" | "article";
}

const {
  title = "Kendall Chacón | Desarrollador Backend",
  description = "Desarrollador backend / full stack enfocado en APIs REST, Laravel, bases de datos relacionales y control de roles.",
  image = "/images/project-preview.jpg",
  type = "website",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Kendall Chacón" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Portafolio de Kendall Chacón" />
    <meta property="og:locale" content="es_CR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href="/favicon.svg" />
  </head>

  <body class="overflow-x-hidden bg-slate-950 text-slate-100 antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div
        class="absolute left-1/2 top-0 h-72 w-72 -translate-x-1/2 rounded-full bg-cyan-400/10 blur-3xl animate-float"
      >
      </div>
      <div
        class="absolute right-0 top-1/3 h-80 w-80 rounded-full bg-blue-500/10 blur-3xl animate-float-slow"
      >
      </div>
      <div
        class="absolute bottom-0 left-0 h-80 w-80 rounded-full bg-indigo-500/10 blur-3xl animate-float"
      >
      </div>
    </div>

    <div class="min-h-screen flex flex-col">
      <Navbar />

      <main class="flex-1 w-full max-w-6xl mx-auto px-4 sm:px-6 page-enter">
        <slot />
      </main>
      <Footer />
    </div>
    <script src="../scripts/site-interactions.js"></script>
  </body>
</html>
