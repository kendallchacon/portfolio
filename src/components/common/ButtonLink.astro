---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  download?: boolean | string;
  target?: string;
  rel?: string;
  class?: string;
}

const {
  href,
  variant = "primary",
  download,
  target,
  rel = target === "_blank" ? "noreferrer" : undefined,
  class: className = "",
} = Astro.props;

const baseClass =
  "inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold transition";
const variantClass =
  variant === "primary"
    ? "btn-primary-animated bg-cyan-400 text-slate-950 hover:bg-cyan-300"
    : "border border-slate-700 text-slate-200 hover:border-cyan-400 hover:text-cyan-400";
---

<a
  href={href}
  download={download}
  target={target}
  rel={rel}
  class:list={[baseClass, variantClass, className]}
>
  <span><slot /></span>
</a>
